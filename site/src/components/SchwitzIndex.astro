---
// Schwitz-Index: gesponserte Metrik (funnytree.de).
// Misst, wie offen der Spielausgang ist: 100 = völlig offen (33/33/33),
// 0 = klare Sache – abgeleitet aus der Wahrscheinlichkeit des Favoriten.
// Rückbau: diese Datei löschen + Import und <SchwitzIndex>-Zeile in
// MatchCard.astro entfernen. Sonst hängt nichts daran.
const { probs } = Astro.props;

const SPONSOR_URL =
  'https://funnytree.de/collections/mikrofaser-handtuecher' +
  '?utm_source=der-automat&utm_medium=referral&utm_campaign=schwitz-index';

const pMax = Math.max(probs.home, probs.draw, probs.away);
const index = Math.min(100, Math.round((1 - pMax) * 150));
const label = index >= 70 ? 'Zitterspiel' : index >= 45 ? 'wird eng' : 'klare Angelegenheit';
const tone = index >= 70 ? 'hot' : index >= 45 ? 'warm' : 'cool';
---

<div class="schwitz">
  <div class="schwitz-head">
    <span
      class="schwitz-title"
      title="Wie offen ist der Ausgang? 100 = völlig offen, 0 = klare Sache – berechnet aus der Siegwahrscheinlichkeit des Favoriten."
    >
      Schwitz-Index
    </span>
    <a class="schwitz-sponsor" href={SPONSOR_URL} target="_blank" rel="noopener">
      präsentiert von <b>funnytree.de</b>
    </a>
  </div>
  <div class="schwitz-meter" role="img" aria-label={`Schwitz-Index ${index} von 100: ${label}`}>
    <div class="schwitz-track">
      <span class:list={['schwitz-fill', tone]} style={`width:${index}%`}></span>
    </div>
    <span class:list={['schwitz-value', tone]}>{index}</span>
    <span class="schwitz-label">{label}</span>
  </div>
</div>

<style>
  .schwitz {
    margin: 14px 22px 0;
    padding: 10px 14px 12px;
    border-radius: var(--r-panel);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--glass-border);
  }
  .schwitz-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 6px 12px;
    margin-bottom: 8px;
  }
  .schwitz-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    cursor: help;
  }
  .schwitz-sponsor {
    font-size: 10.5px;
    color: var(--text-muted);
    text-decoration: none;
  }
  .schwitz-sponsor b { font-weight: 700; color: inherit; }
  .schwitz-sponsor:hover { color: var(--lime); text-decoration: underline; }

  .schwitz-meter {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .schwitz-track {
    position: relative;
    flex: 1;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .schwitz-fill {
    position: absolute;
    inset: 0 auto 0 0;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .schwitz-fill.cool { background: #8b93a5; }
  .schwitz-fill.warm { background: var(--gold); box-shadow: 0 0 10px rgba(232, 201, 106, 0.35); }
  .schwitz-fill.hot { background: var(--red); box-shadow: 0 0 10px rgba(255, 77, 94, 0.4); }

  .schwitz-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    min-width: 2ch;
    text-align: right;
  }
  .schwitz-value.cool { color: var(--text-muted); }
  .schwitz-value.warm { color: var(--gold); }
  .schwitz-value.hot { color: var(--red); }

  .schwitz-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }
</style>
