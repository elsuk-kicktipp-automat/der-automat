# Vorlage: nach .env kopieren und ausfüllen. Die .env ist gitignored.

# Versiegelung (Phase 2): Schlüssel für die Fernet-Verschlüsselung der
# Klartext-Tipps. Muss identisch als GitHub Actions Secret hinterlegt sein:
#   gh secret set SEAL_SECRET --repo elsuk-kicktipp-automat/der-automat --body "..."
SEAL_SECRET=

# LLM-Schicht (Phase 3): Begründungstexte via Groq Free Tier (config.yaml: llm.provider).
# Ohne Key/Netzwerk fällt das System automatisch auf die Template-Begründung zurück.
# Key erstellen: https://console.groq.com/keys
GROQ_API_KEY=

# Quoten-Prior (concept.md §3): The Odds API, Free Tier 500 Requests/Monat.
# Ohne Key läuft das Modell ohne Quoten-Blend (nur ELO-Prior).
# Key erstellen: https://the-odds-api.com
ODDS_API_KEY=

# Kicktipp-Bot (Phase 4, live) – eigener Bot-Account, nie der persönliche:
KICKTIPP_EMAIL=
KICKTIPP_PASSWORD=
KICKTIPP_RUNDE=
